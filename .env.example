# ==========================================
# VARIABLES DE ENTORNO PARA PRODUCCIÓN (RENDER)
# ==========================================
# Carga estas variables directamente en el panel de Environment de Render.
# ¡NUNCA subas este archivo con credenciales reales a GitHub!

# Base de datos (Supabase)
DB_URL=jdbc:postgresql://aws-0-sa-east-1.pooler.supabase.com:6543/postgres # (Ejemplo, usa tu URL de Supabase)
DB_USERNAME=postgres.tu-proyecto
DB_PASSWORD=tu_contraseña_segura

# Seguridad (Deben ser strings largos y seguros)
JWT_SECRET=super_secret_key_de_al_menos_32_caracteres_en_produccion
ENCRYPTION_KEY=clave_de_encriptacion_de_32_chars_exactamente

# Whatsapp (Ultramsg o Twilio)
WHATSAPP_PROVIDER=ultramsg
ULTRAMSG_INSTANCE_ID=instance123456
ULTRAMSG_TOKEN=tu_token_aqui

# Google App Script (Para turnos, si aplica)
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/xyz/exec
GOOGLE_SCRIPT_TOKEN=PsyGst_Token_Produccion

# Frontend Config
CORS_ORIGINS=https://psygst-frontend.vercel.app # Reemplazar con el dominio real de Vercel
